<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:background="@color/dark_green"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:background="@drawable/bg_campo"
                android:text="SP"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="18sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="@string/app_name"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:gravity="center"
            android:background="@color/light_gray"
            android:text="Mapa de parqueaderos"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="22sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtUbicacion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ubicacion_actual"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="16sp" />

            <Space android:layout_width="match_parent" android:layout_height="12dp" />

            <Button
                android:id="@+id/btnUbicacion"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_boton"
                android:text="@string/obtener_ubicacion"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <Space android:layout_width="match_parent" android:layout_height="12dp" />

            <Button
                android:id="@+id/btnBuscarParqueadero"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_boton"
                android:text="@string/buscar_parqueadero"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <Space android:layout_width="match_parent" android:layout_height="12dp" />

            <Button
                android:id="@+id/btnBusquedaVoz"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_boton"
                android:text="@string/buscar_por_voz"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <Space android:layout_width="match_parent" android:layout_height="18dp" />

            <Button
                android:id="@+id/btnParqueadero1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_campo"
                android:text="Parqueadero Javeriana&#10;150 m • 8 espacios disponibles"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:padding="16dp" />

            <Space android:layout_width="match_parent" android:layout_height="12dp" />

            <Button
                android:id="@+id/btnParqueadero2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_campo"
                android:text="Parqueadero Marly&#10;300 m • 5 espacios disponibles"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:padding="16dp" />

            <Button
                android:id="@+id/btnNotificaciones"
                android:layout_width="48dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_boton"
                android:text="🔔"
                android:textAllCaps="false"
                android:textColor="@color/white" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>