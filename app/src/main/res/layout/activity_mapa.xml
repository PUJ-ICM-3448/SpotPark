<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:background="@color/dark_green"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:background="@drawable/bg_campo"
                android:text="SP"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="18sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="@string/app_name"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnNotificaciones"
                android:layout_width="48dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_boton"
                android:text="🔔"
                android:textAllCaps="false"
                android:textColor="@color/white" />

        </LinearLayout>

        <fragment
            android:id="@+id/mapFragment"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="16dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="120dp"
        app:behavior_hideable="false">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="@color/dark_green"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etBuscarDireccion"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:hint="Buscar dirección..."
            android:background="@drawable/bg_campo"
            android:textColor="@color/white"
            android:textColorHint="#AAFFFFFF"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:singleLine="true" />

        <Space android:layout_width="match_parent" android:layout_height="12dp" />

        <Button
            android:id="@+id/btnUbicacion"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_boton"
            android:text="@string/obtener_ubicacion"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <Space android:layout_width="match_parent" android:layout_height="12dp" />

        <Button
            android:id="@+id/btnParqueadero1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_campo"
            android:text="Parqueadero Javeriana&#10;150 m • 8 espacios disponibles"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:padding="16dp" />

        <Space android:layout_width="match_parent" android:layout_height="12dp" />

        <Button
            android:id="@+id/btnParqueadero2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_campo"
            android:text="Parqueadero Marly&#10;300 m • 5 espacios disponibles"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:padding="16dp" />

        <Space android:layout_width="match_parent" android:layout_height="12dp" />

        <Button
            android:id="@+id/btnBusquedaVoz"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_boton"
            android:text="@string/buscar_por_voz"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <!-- 🔥 NUEVO BOTÓN HARDWARE -->
        <Space android:layout_width="match_parent" android:layout_height="12dp" />

        <Button
            android:id="@+id/btnHardware"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_boton"
            android:text="Subir evidencia"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>