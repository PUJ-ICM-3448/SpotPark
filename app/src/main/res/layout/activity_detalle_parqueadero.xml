<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/dark_green">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <Space android:layout_width="match_parent" android:layout_height="40dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/detalle_parqueadero"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="22sp" />

        <Space android:layout_width="match_parent" android:layout_height="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_campo"
            android:padding="20dp">

            <TextView
                android:id="@+id/txtNombreParqueadero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/parqueadero_javeriana"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/txtDireccion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/direccion_javeriana"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/txtDistancia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/distancia_javeriana"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/txtDisponibilidad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/disponibilidad_texto"
                android:textColor="@color/white"
                android:textSize="16sp" />
        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="18dp" />

        <Button
            android:id="@+id/btnIniciarRuta"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_boton"
            android:text="@string/iniciar_ruta"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <Space android:layout_width="match_parent" android:layout_height="12dp" />

        <Button
            android:id="@+id/btnReportar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_boton"
            android:text="@string/reportar_disponibilidad"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <Space android:layout_width="match_parent" android:layout_height="12dp" />

        <Button
            android:id="@+id/btnVolverMapa"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_boton"
            android:text="@string/volver_mapa"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>